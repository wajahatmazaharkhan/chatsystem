{
  "info": {
    "_postman_id": "9ec158f8-0a3f-4be7-943c-79ebc1b70598",
    "name": "Chatsystem User Management",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "userId",
      "value": "replace-with-user-id"
    }
  ],
  "item": [
    {
      "name": "Get all users",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/users",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Filter by role",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/users?role=STUDENT",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users"
          ],
          "query": [
            {
              "key": "role",
              "value": "STUDENT"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "Filter by status",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/users?status=ACTIVE",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users"
          ],
          "query": [
            {
              "key": "status",
              "value": "ACTIVE"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "Combined filters",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/users?role=STUDENT&status=ACTIVE",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users"
          ],
          "query": [
            {
              "key": "role",
              "value": "STUDENT"
            },
            {
              "key": "status",
              "value": "ACTIVE"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get user by ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/users/{{userId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users",
            "{{userId}}"
          ]
        }
      },
      "response": []
    }
  ]
}
